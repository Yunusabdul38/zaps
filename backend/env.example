# BLINKS Backend Environment Variables

# Database
BLINKS_DATABASE__URL=postgres://username:password@localhost/BLINKS
BLINKS_DATABASE__MAX_POOL_SIZE=16

# Server
BLINKS_PORT=3000

# JWT Configuration
BLINKS_JWT__SECRET=your-super-secret-jwt-key-change-this-in-production
BLINKS_JWT__EXPIRATION_HOURS=1
BLINKS_JWT__REFRESH_EXPIRATION_HOURS=168

# Stellar Network Configuration
BLINKS_STELLAR__NETWORK__PASSPHRASE=Test SDF Network ; September 2015
BLINKS_STELLAR__NETWORK__HORIZON_URL=https://horizon-testnet.stellar.org
BLINKS_STELLAR__NETWORK__RPC_URL=https://soroban-testnet.stellar.org

# Anchor Configuration
BLINKS_ANCHOR__SEP24_URL=https://your-anchor.com/sep24
BLINKS_ANCHOR__SEP31_URL=https://your-anchor.com/sep31
BLINKS_ANCHOR__WEBHOOK_SECRET=your-webhook-secret
BLINKS_ANCHOR__KYC_REQUIRED=true

# Bridge Configuration
BLINKS_BRIDGE__ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
BLINKS_BRIDGE__POLYGON_RPC_URL=https://polygon-rpc.com
BLINKS_BRIDGE__BSC_RPC_URL=https://bsc-dataseed.binance.org
BLINKS_BRIDGE__SUPPORTED_ASSETS=["USDC", "USDT"]
BLINKS_BRIDGE__MIN_BRIDGE_AMOUNT=1000000
BLINKS_BRIDGE__MAX_BRIDGE_AMOUNT=100000000

# Compliance Configuration
BLINKS_COMPLIANCE__SANCTIONS_API_URL=https://api.sanctions.example.com
BLINKS_COMPLIANCE__SANCTIONS_API_KEY=your-api-key
BLINKS_COMPLIANCE__ALERT_WEBHOOK_URL=https://hooks.example.com/compliance-alerts
BLINKS_COMPLIANCE__VELOCITY_LIMITS__DAILY_TRANSACTION_LIMIT=10000000
BLINKS_COMPLIANCE__VELOCITY_LIMITS__MONTHLY_TRANSACTION_LIMIT=100000000
BLINKS_COMPLIANCE__VELOCITY_LIMITS__MAX_TRANSACTION_AMOUNT=5000000
BLINKS_COMPLIANCE__RISK_THRESHOLDS__HIGH_RISK_AMOUNT=10000000
BLINKS_COMPLIANCE__RISK_THRESHOLDS__MEDIUM_RISK_AMOUNT=1000000

# Rate Limit Configuration
BLINKS_RATE_LIMIT__WINDOW_MS=60000
BLINKS_RATE_LIMIT__MAX_REQUESTS=100
BLINKS_RATE_LIMIT__SCOPE=IP

# Observability
LOG_FORMAT=json
RUST_LOG=blinks_backend=info,tower_http=info
BLINKS_OBSERVABILITY__SERVICE_NAME=blinks-backend
BLINKS_OBSERVABILITY__SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
BLINKS_OBSERVABILITY__ALERT_WEBHOOK_URL=https://hooks.example.com/platform-alerts
BLINKS_OBSERVABILITY__LOG_RETENTION_DAYS=30

# Cache / Redis
BLINKS_CACHE__REDIS_URL=redis://localhost:6379
BLINKS_CACHE__DEFAULT_TTL_SECONDS=300
BLINKS_CACHE__HOT_DATA_TTL_SECONDS=60

# Environment
RUN_ENV=development
